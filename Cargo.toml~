[package]
name = "cisis"
version = "0.1.0"
edition = "2024"
authors = ["Gibran abi hilal"]
description = "Package to check file type easly!"

[dependencies]
infer = "0.15"
rayon = "1.8"
clap = { version = "4.4", features = ["derive"] }
anyhow = "1.0"
colored = "2.0"
walkdir = "2.4"
content_inspector = "0.2"

[profile.release]
opt-level = "z"
lto = true
codegen-units = 1
panic = "abort"
